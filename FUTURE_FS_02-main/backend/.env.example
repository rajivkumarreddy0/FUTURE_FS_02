# Local MySQL connection using a full URI
DATABASE_URL=mysql://root:your_mysql_password@localhost:3306/crm_db

# Or use individual connection variables (optional)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=crm_db
DB_PORT=3306

PORT=5000
JWT_SECRET=your_secret_key
ADMIN_EMAIL=your@email.com
ADMIN_PASSWORD=your_password
